/frontend-*/
/frontend.*/

# ── Frontend (React + Vite) ── keep `frontend/` itself, ignore build trash
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/.cache/
frontend/.parcel-cache/
frontend/.next/
frontend/.turbo/
frontend/coverage/
