# Reyna — Environment Configuration
# Copy this to .env and fill in your values: cp .env.example .env

# ── Server ──
PORT=8080
DATABASE_URL=./reyna.db
JWT_SECRET=change-this-to-a-random-secret-in-production
FRONTEND_URL=http://localhost:5173

# ── Google Drive ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# ── LLM Provider ──
# Pick one. Set the key for whichever provider you want to use.
# If LLM_PROVIDER is left empty, reyna auto-detects from whichever key is set.
LLM_PROVIDER=gemini

# Gemini (default, recommended) -- get a free key at aistudio.google.com/apikey
GEMINI_API_KEY=

# Claude (Anthropic) -- console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI -- platform.openai.com/api-keys
OPENAI_API_KEY=

# Grok (xAI) -- console.x.ai
XAI_API_KEY=

# ── Auto-Commit ──
# Hours before staged files auto-commit to drive (default 24)
AUTO_COMMIT_HOURS=24

# ── Qdrant (Reyna's Recall + Memory) ──
# Vector DB for semantic search. Leave QDRANT_URL empty to disable
# semantic search (keyword-only fallback).
# Free cloud: cloud.qdrant.io → "Clusters" → "Get API Key"
QDRANT_URL=
QDRANT_API_KEY=

# ── Vapi (Reyna Live — voice agent) ──
# VAPI_WEBHOOK_SECRET: random string; set the same value in the Vapi assistant
#   tool settings as "Server URL Secret". Reyna verifies it on every tool call.
# VAPI_PUBLIC_KEY: exposed to the frontend for the "Call Reyna" web button.
# VAPI_ASSISTANT_ID: the assistant the web button dials.
VAPI_WEBHOOK_SECRET=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
